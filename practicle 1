#include <iostream>
using namespace std;

int main() {
    int n;
    cout << "Enter value of n: ";
    cin >> n;

    double sum = 0;

    for (int i = 1; i <= n; i++) {
        double power = 1;

        // find i^i
        for (int j = 1; j <= i; j++) {
            power = power * i;
        }

        if (i % 2 == 0)
            sum = sum - (1 / power);
        else
            sum = sum + (1 / power);
    }

    cout << "Sum = " << sum;

    return 0;
}
